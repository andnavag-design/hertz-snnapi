  document.getElementById('cdp-body').innerHTML=`<div class="detail-section"><div class="detail-section-title">Información del cliente</div><div class="detail-row"><span class="detail-label">Nombre</span><span class="detail-val">${c.nombre}</span></div><div class="detail-row"><span class="detail-label">Cédula</span><span class="detail-val">${c.cedula}</span></div><div class="detail-row"><span class="detail-label">Teléfono</span><span class="detail-val">${c.tel}</span></div><div class="detail-row"><span class="detail-label">Licencia</span><span class="detail-val">${c.licencia}</span></div><div class="detail-row"><span class="detail-label">Vence licencia</span><span class="detail-val">${c.licVence}</span></div><div class="detail-row"><span class="detail-label">Cliente desde</span><span class="detail-val">${c.desde}</span></div><div class="detail-row"><span class="detail-label">Perfil</span><span class="detail-val">${perfilPill(c.perfil)}</span></div></div><div class="detail-section"><div class="detail-section-title">Resumen</div><div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;"><div style="background:var(--hz-mist);border-radius:4px;padding:10px;text-align:center;border-top:2px solid var(--hz-yellow);"><div style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;">${c.rentas}</div><div style="font-size:10px;color:var(--hz-steel);">Rentas</div></div><div style="background:var(--hz-mist);border-radius:4px;padding:10px;text-align:center;border-top:2px solid var(--hz-yellow);"><div style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;">${c.inspecciones}</div><div style="font-size:10px;color:var(--hz-steel);">Inspecciones</div></div><div style="background:var(--hz-mist);border-radius:4px;padding:10px;text-align:center;border-top:2px solid ${c.daños>0?'var(--red)':'var(--green)'};"><div style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:${c.daños>0?'var(--red)':'var(--green-dark)'};">${c.daños}</div><div style="font-size:10px;color:var(--hz-steel);">Daños</div></div></div></div><div class="detail-section"><div class="detail-section-title">Score de riesgo</div><div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;"><div style="flex:1;height:9px;background:var(--hz-mist);border-radius:2px;overflow:hidden;"><div style="width:${riesgo.pct}%;height:100%;background:${riesgo.color};border-radius:2px;"></div></div><span style="font-size:13px;font-weight:700;color:${riesgo.color};">${riesgo.label}</span></div><div style="font-size:11px;color:var(--hz-steel);">Basado en historial de daños, rentas completadas y firma digital.</div></div><div class="detail-section"><div class="detail-section-title">Historial reciente</div>${histHtml}${c.rentas>3?`<div style="font-size:11px;color:var(--hz-yellow-dark);font-weight:700;margin-top:8px;cursor:pointer;">Ver todas las rentas (${c.rentas}) →</div>`:''}</div><div class="panel-actions"><button class="btn-sm btn-sm-primary">📋 Ver historial completo</button><button class="btn-sm btn-sm-ghost">📧 Contactar</button></div>`;
  document.querySelectorAll('#cli-tbody tr').forEach(tr=>tr.classList.toggle('selected',parseInt(tr.dataset.cid)===id));
}
