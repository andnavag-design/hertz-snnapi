<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hertz — Dashboard Supervisor</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --hz-yellow:#F5C400;
  --hz-yellow-dark:#C9A000;
  --hz-black:#0A0A0A;
  --hz-charcoal:#1C1C1C;
  --hz-mid:#2E2E2E;
  --hz-steel:#5A5A5A;
  --hz-mist:#F2F2F2;
  --hz-border:#E0E0E0;
  --white:#FFFFFF;
  --green:#22C55E;
  --green-dark:#15803D;
  --red:#DC2626;
  --orange:#F59E0B;
  --sidebar:224px;
}
body{font-family:'Inter',sans-serif;background:var(--hz-mist);color:var(--hz-black);display:flex;min-height:100vh;}
 
/* ── SIDEBAR ── */
.sidebar{width:var(--sidebar);background:var(--hz-black);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;border-right:3px solid var(--hz-yellow);}
.sb-logo{padding:20px 20px 16px;border-bottom:1px solid rgba(255,255,255,0.07);}
.sb-logo-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:28px;color:var(--white);line-height:1;letter-spacing:-0.5px;}
.sb-logo-bar{width:36px;height:3px;background:var(--hz-yellow);margin-top:5px;border-radius:1px;}
.sb-logo-sub{font-size:10px;color:rgba(255,255,255,0.35);margin-top:5px;text-transform:uppercase;letter-spacing:1px;}
.sb-section{padding:18px 16px 6px;font-size:10px;font-weight:700;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:1.5px;}
.sb-item{display:flex;align-items:center;gap:10px;padding:10px 14px;margin:1px 8px;border-radius:4px;font-size:13px;font-weight:500;color:rgba(255,255,255,0.5);cursor:pointer;transition:all 0.15s;}
.sb-item:hover{background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.85);}
.sb-item.active{background:var(--hz-yellow);color:var(--hz-black);font-weight:700;}
.sb-item-icon{font-size:15px;width:20px;text-align:center;}
.sb-badge{margin-left:auto;background:var(--red);color:white;font-size:10px;font-weight:700;padding:2px 6px;border-radius:3px;}
.sb-item.active .sb-badge{background:rgba(0,0,0,0.25);color:var(--hz-black);}
.sb-footer{margin-top:auto;padding:14px 16px;border-top:1px solid rgba(255,255,255,0.07);}
.sb-user{display:flex;align-items:center;gap:10px;}
.sb-avatar{width:34px;height:34px;border-radius:50%;background:var(--hz-yellow);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:var(--hz-black);flex-shrink:0;}
.sb-user-name{font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);}
.sb-user-role{font-size:10px;color:rgba(255,255,255,0.35);}
 
/* ── MAIN ── */
.main{margin-left:var(--sidebar);flex:1;display:flex;flex-direction:column;}
.topbar{background:var(--white);border-bottom:1px solid var(--hz-border);border-left:none;padding:0 28px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar-title{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--hz-black);letter-spacing:0.3px;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.topbar-date{font-size:12px;color:var(--hz-steel);}
.notif-btn{width:34px;height:34px;border-radius:4px;background:var(--hz-mist);display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;position:relative;border:1px solid var(--hz-border);}
.notif-dot{position:absolute;top:6px;right:6px;width:7px;height:7px;background:var(--red);border-radius:50%;border:2px solid white;}
.btn-export{padding:8px 16px;border-radius:4px;background:var(--hz-yellow);color:var(--hz-black);font-size:12px;font-weight:700;border:none;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:0.2px;}
 
/* ── VIEWS ── */
.section-view{display:none;padding:24px 28px;flex-direction:column;gap:20px;}
.section-view.active{display:flex;}
 
/* ── KPI CARDS ── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
.kpi{background:var(--white);border-radius:4px;border:1px solid var(--hz-border);padding:18px;display:flex;flex-direction:column;gap:8px;border-top:3px solid var(--hz-yellow);}
.kpi-header{display:flex;align-items:center;justify-content:space-between;}
.kpi-label{font-size:11px;font-weight:700;color:var(--hz-steel);text-transform:uppercase;letter-spacing:0.8px;}
.kpi-icon{width:34px;height:34px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:17px;}
.kpi-num{font-family:'Barlow Condensed',sans-serif;font-size:34px;font-weight:800;color:var(--hz-black);line-height:1;letter-spacing:-0.5px;}
.kpi-delta{display:flex;align-items:center;gap:5px;font-size:12px;font-weight:500;}
.delta-up{color:var(--green);}
.delta-down{color:var(--red);}
.delta-neutral{color:var(--hz-steel);}
.kpi-sub{font-size:11px;color:var(--hz-steel);}
.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:-4px;}
.section-title{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:var(--hz-black);letter-spacing:0.3px;}
.section-action{font-size:12px;color:var(--hz-yellow-dark);font-weight:700;cursor:pointer;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.three-col{display:grid;grid-template-columns:2fr 1fr;gap:18px;}
.card{background:var(--white);border-radius:4px;border:1px solid var(--hz-border);overflow:hidden;}
.card-head{padding:14px 18px;border-bottom:1px solid var(--hz-border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:13px;font-weight:700;color:var(--hz-black);display:flex;align-items:center;gap:8px;}
.card-accent-bar{width:16px;height:3px;background:var(--hz-yellow);border-radius:1px;flex-shrink:0;}
.card-sub{font-size:11px;color:var(--hz-steel);}
 
/* ── TABLES ── */
.table{width:100%;border-collapse:collapse;}
.table th{font-size:10px;font-weight:700;color:var(--hz-steel);text-transform:uppercase;letter-spacing:0.8px;padding:9px 18px;text-align:left;background:var(--hz-mist);border-bottom:1px solid var(--hz-border);}
.table td{padding:12px 18px;font-size:13px;border-bottom:1px solid var(--hz-border);color:var(--hz-black);vertical-align:middle;}
.table tr:last-child td{border-bottom:none;}
.table tbody tr{cursor:pointer;}
.table tbody tr:hover td{background:#FFFDE7;}
.table tbody tr.selected td{background:#FFF9C4;border-left:3px solid var(--hz-yellow);}
 
/* ── PILLS ── */
.pill{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:3px;}
.pill-ok{background:#F0FDF4;color:#166534;border:1px solid #BBF7D0;}
.pill-warn{background:#FFFBEB;color:#92400E;border:1px solid #FDE68A;}
.pill-danger{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA;}
.pill-pending{background:#EFF6FF;color:#1E40AF;border:1px solid #BFDBFE;}
.pill-gray{background:var(--hz-mist);color:var(--hz-steel);border:1px solid var(--hz-border);}
.pill-yellow{background:#FFFDE7;color:var(--hz-yellow-dark);border:1px solid var(--hz-yellow);}
 
/* ── VEHICLE ── */
.veh-name{font-weight:600;font-size:13px;color:var(--hz-black);}
.veh-plate{display:inline-block;background:var(--hz-black);color:white;font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;letter-spacing:1.5px;margin-top:2px;}
 
/* ── BAR CHART ── */
.bar-chart{padding:14px 18px 12px;display:flex;flex-direction:column;gap:10px;}
.bar-row{display:flex;align-items:center;gap:10px;}
.bar-label{font-size:12px;color:var(--hz-steel);width:80px;flex-shrink:0;}
.bar-track{flex:1;height:7px;background:var(--hz-mist);border-radius:2px;overflow:hidden;}
.bar-fill{height:100%;border-radius:2px;background:var(--hz-yellow);}
.bar-val{font-size:12px;font-weight:700;color:var(--hz-black);width:28px;text-align:right;flex-shrink:0;}
 
/* ── DONUT ── */
.donut-wrap{padding:14px 18px;display:flex;align-items:center;gap:18px;}
.donut{width:96px;height:96px;border-radius:50%;flex-shrink:0;background:conic-gradient(var(--green) 0% 62%,var(--orange) 62% 80%,var(--red) 80% 100%);display:flex;align-items:center;justify-content:center;position:relative;}
.donut::after{content:'';position:absolute;width:62px;height:62px;background:white;border-radius:50%;}
.donut-center{position:relative;z-index:1;text-align:center;}
.donut-num{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--hz-black);line-height:1;}
.donut-sub{font-size:9px;color:var(--hz-steel);}
.donut-legend{display:flex;flex-direction:column;gap:7px;}
.legend-item{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--hz-steel);}
.legend-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
 
/* ── ALERT FEED ── */
.alert-feed{display:flex;flex-direction:column;}
.alert-item{display:flex;align-items:flex-start;gap:12px;padding:13px 18px;border-bottom:1px solid var(--hz-border);}
.alert-item:last-child{border-bottom:none;}
.alert-icon{width:34px;height:34px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.icon-red{background:#FEF2F2;}.icon-yellow{background:#FFFBEB;}.icon-green{background:#F0FDF4;}.icon-blue{background:#EFF6FF;}
.alert-body{flex:1;}
.alert-title{font-size:13px;font-weight:600;color:var(--hz-black);}
.alert-meta{font-size:11px;color:var(--hz-steel);margin-top:2px;}
.alert-time{font-size:11px;color:var(--hz-steel);white-space:nowrap;}
 
/* ── INVENTORY ── */
.inv-row{display:flex;align-items:center;justify-content:space-between;padding:11px 18px;border-bottom:1px solid var(--hz-border);}
.inv-row:last-child{border-bottom:none;}
.inv-left{display:flex;align-items:center;gap:12px;}
.inv-icon{width:38px;height:38px;border-radius:4px;background:var(--hz-mist);display:flex;align-items:center;justify-content:center;font-size:18px;}
.inv-name{font-size:13px;font-weight:600;color:var(--hz-black);}
.inv-plate{font-size:10px;color:var(--hz-steel);font-weight:600;letter-spacing:1px;}
.inv-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;}
.inv-date{font-size:11px;color:var(--hz-steel);}
.days-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;}
.days-ok{background:#F0FDF4;color:#166534;}.days-warn{background:#FFFBEB;color:#92400E;}.days-danger{background:#FEF2F2;color:#991B1B;}
 
/* ── MINI KPIS ── */
.mini-kpis{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--hz-border);}
.mini-kpi{background:white;padding:14px 18px;}
.mini-kpi-num{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:800;color:var(--hz-black);}
.mini-kpi-num.red{color:var(--red);}.mini-kpi-num.green{color:var(--green-dark);}
.mini-kpi-label{font-size:11px;color:var(--hz-steel);margin-top:2px;}
 
/* ── INSPECCIONES VIEW ── */
.insp-layout{display:grid;grid-template-columns:1fr 380px;gap:18px;align-items:start;}
.filter-bar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.filter-chip{padding:6px 14px;border-radius:3px;border:1.5px solid var(--hz-border);background:white;font-size:12px;font-weight:600;color:var(--hz-steel);cursor:pointer;transition:all 0.15s;}
.filter-chip:hover{border-color:var(--hz-black);color:var(--hz-black);}
.filter-chip.active{border-color:var(--hz-yellow);background:var(--hz-yellow);color:var(--hz-black);}
.search-input{padding:8px 14px;border:1.5px solid var(--hz-border);border-radius:4px;font-size:13px;font-family:'Inter',sans-serif;color:var(--hz-black);outline:none;width:220px;}
.search-input:focus{border-color:var(--hz-yellow);}
 
/* ── DETAIL PANEL ── */
.detail-panel{background:white;border-radius:4px;border:1px solid var(--hz-border);position:sticky;top:72px;display:none;}
.detail-panel.visible{display:block;}
.detail-header{padding:16px 18px;background:var(--hz-black);border-radius:4px 4px 0 0;border-bottom:3px solid var(--hz-yellow);}
.detail-title{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:white;letter-spacing:0.3px;}
.detail-sub{font-size:11px;color:rgba(255,255,255,0.45);margin-top:3px;}
.detail-close{background:none;border:none;color:rgba(255,255,255,0.4);font-size:16px;cursor:pointer;float:right;margin-top:-1px;}
.detail-body{padding:0;}
.detail-section{padding:13px 16px;border-bottom:1px solid var(--hz-border);}
.detail-section:last-child{border-bottom:none;}
.detail-section-title{font-size:10px;font-weight:700;color:var(--hz-steel);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;}
.detail-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:12px;}
.detail-label{color:var(--hz-steel);}
.detail-val{font-weight:600;color:var(--hz-black);}
 
/* ── PHOTO GALLERY ── */
.photo-grid-gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-top:8px;}
.photo-thumb{border-radius:4px;overflow:hidden;border:1.5px solid var(--hz-border);cursor:pointer;transition:all 0.15s;background:white;}
.photo-thumb:hover{border-color:var(--hz-yellow);transform:translateY(-1px);}
.photo-thumb.has-damage{border-color:var(--red);}
.photo-thumb.has-preex{border-color:var(--orange);}
.photo-thumb.missing{opacity:0.5;cursor:default;}
.photo-thumb.missing:hover{transform:none;border-color:var(--hz-border);}
.photo-thumb-preview{aspect-ratio:1;background:var(--hz-mist);display:flex;align-items:center;justify-content:center;font-size:20px;position:relative;}
.photo-thumb.has-damage .photo-thumb-preview{background:#FEF2F2;}
.photo-thumb.has-preex .photo-thumb-preview{background:#FFFBEB;}
.photo-badge-new{position:absolute;top:3px;right:3px;width:15px;height:15px;background:var(--red);border-radius:50%;color:white;font-size:8px;font-weight:800;display:flex;align-items:center;justify-content:center;border:1.5px solid white;}
.photo-badge-pre{position:absolute;top:3px;right:3px;width:15px;height:15px;background:var(--orange);border-radius:50%;color:white;font-size:8px;font-weight:800;display:flex;align-items:center;justify-content:center;border:1.5px solid white;}
.photo-thumb-label{font-size:9px;font-weight:700;color:var(--hz-black);text-align:center;padding:3px 3px 0;}
.photo-thumb-status{font-size:8px;text-align:center;padding:1px 3px 4px;font-weight:700;}
.status-ok{color:var(--green-dark);}.status-dmg{color:var(--red);}.status-pre{color:var(--orange);}
.missing-status{color:var(--hz-steel);}
 
/* ── PHOTO OVERLAY ── */
.photo-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:999;align-items:center;justify-content:center;}
.overlay-card{background:white;border-radius:6px;width:420px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.5);}
.overlay-preview{height:260px;background:var(--hz-mist);display:flex;align-items:center;justify-content:center;font-size:80px;position:relative;border-bottom:3px solid var(--hz-yellow);}
.overlay-close{position:absolute;top:10px;right:10px;width:30px;height:30px;border-radius:50%;background:rgba(0,0,0,0.3);color:white;border:none;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.overlay-info{padding:14px 18px 18px;}
.overlay-title{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--hz-black);margin-bottom:6px;letter-spacing:0.3px;}
.overlay-badge{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:3px;margin-bottom:10px;}
.badge-ok{background:#F0FDF4;color:#166534;border:1px solid #BBF7D0;}
.badge-warn{background:#FFFBEB;color:#92400E;border:1px solid #FDE68A;}
.badge-danger{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA;}
.overlay-meta{font-size:12px;color:var(--hz-steel);line-height:1.6;}
.overlay-actions{display:flex;gap:8px;margin-top:12px;}
 
/* ── CAR MAP PANEL ── */
.car-map-panel{position:relative;background:var(--hz-mist);border-radius:4px;padding:14px;display:flex;justify-content:center;margin-top:8px;min-height:200px;border:1px solid var(--hz-border);}
.car-map-panel svg{width:120px;}
.dmg-pin{position:absolute;display:flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;font-size:9px;font-weight:800;color:white;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.25);cursor:pointer;transition:transform 0.15s;}
.dmg-pin:hover{transform:scale(1.25);}
.dmg-pin.scratch{background:var(--orange);}
.dmg-pin.dent{background:var(--red);}
.dmg-pin.new-damage{background:var(--red);box-shadow:0 0 0 3px rgba(220,38,38,0.25),0 2px 6px rgba(0,0,0,0.25);animation:pulse-red 1.5s infinite;}
@keyframes pulse-red{0%,100%{box-shadow:0 0 0 3px rgba(220,38,38,0.25)}50%{box-shadow:0 0 0 6px rgba(220,38,38,0.1)}}
.map-legend{display:flex;gap:12px;margin-top:8px;justify-content:center;flex-wrap:wrap;}
.map-legend-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--hz-steel);}
.map-legend-dot{width:9px;height:9px;border-radius:50%;}
 
/* ── DAMAGE LIST IN PANEL ── */
.dmg-entry{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--hz-border);font-size:12px;}
.dmg-entry:last-child{border-bottom:none;}
.dmg-dot-sm{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
 
/* ── TIMELINE IN PANEL ── */
.tl-mini{display:flex;flex-direction:column;gap:0;}
.tl-mi{display:flex;gap:10px;padding-bottom:12px;position:relative;}
.tl-mi:last-child{padding-bottom:0;}
.tl-md{width:26px;height:26px;border-radius:50%;background:var(--hz-black);border:2px solid var(--hz-yellow);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;position:relative;z-index:1;}
.tl-ml{position:absolute;left:12px;top:26px;bottom:0;width:2px;background:var(--hz-border);}
.tl-mt{font-size:12px;font-weight:600;color:var(--hz-black);padding-top:3px;}
.tl-mm{font-size:10px;color:var(--hz-steel);margin-top:1px;}
 
/* ── ACTION BTNS IN PANEL ── */
.panel-actions{display:flex;gap:8px;padding:12px 16px;}
.btn-sm{padding:8px 14px;border-radius:4px;font-size:12px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;border:none;}
.btn-sm-primary{background:var(--hz-yellow);color:var(--hz-black);}
.btn-sm-ghost{background:var(--hz-mist);color:var(--hz-steel);border:1.5px solid var(--hz-border);}
 
/* ── EMPTY STATE ── */
.empty-panel{padding:40px 20px;text-align:center;}
.empty-icon{font-size:36px;margin-bottom:10px;}
.empty-text{font-size:13px;color:var(--hz-steel);}
 
/* ── ANALÍTICA INSIGHT ── */
.insight-box{margin-top:14px;background:#FFFDE7;border:1px solid var(--hz-yellow);border-radius:4px;padding:11px 14px;display:flex;gap:10px;align-items:center;}
.insight-box span{font-size:18px;}
.insight-box div{font-size:13px;color:var(--hz-black);line-height:1.5;}
 
/* ── AI SUMMARY BOX ── */
.ai-summary{background:var(--hz-mist);border-radius:4px;padding:12px;border-left:3px solid var(--hz-yellow);}
.ai-summary-label{font-size:10px;font-weight:700;color:var(--hz-yellow-dark);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;}
.ai-summary-text{font-size:12px;color:var(--hz-black);line-height:1.6;}
 
/* ── PROGRESS BARS ── */
.prog-track{flex:1;height:9px;background:var(--hz-mist);border-radius:2px;overflow:hidden;}
.prog-fill-yellow{height:100%;background:var(--hz-yellow);border-radius:2px;}
.prog-fill-green{height:100%;background:var(--green);border-radius:2px;}
 
/* ── CLIENTES ── */
.cli-avatar{width:32px;height:32px;border-radius:50%;background:var(--hz-black);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--hz-yellow);flex-shrink:0;}
</style>
